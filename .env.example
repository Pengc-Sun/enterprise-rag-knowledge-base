APP_NAME="Enterprise RAG Knowledge Base"
APP_ENV=development
DEBUG=true

API_V1_PREFIX=/api/v1

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_rag
POSTGRES_USER=enterprise_rag
POSTGRES_PASSWORD=enterprise_rag
DATABASE_URL=postgresql+asyncpg://enterprise_rag:enterprise_rag@postgres:5432/enterprise_rag

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

UPLOAD_DIR=storage/uploads

